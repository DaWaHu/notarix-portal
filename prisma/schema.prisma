// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model IntakeSubmission {
  vendor    Vendor?  @relation("VendorIntake")
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // CLIENT or NOTARY
  role String

  // Contact info
  fullName String
  email    String
  phone    String?

  // Extra info from the form
  message String?
  details Json?

  // Tracking for your team
  status String @default("NEW") // NEW, CONTACTED, SCHEDULED, CLOSED
}

model Vendor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // The vendor assigned number you described (example: 1000126NC260131A)
  vendorcode String @unique

  // Profile info
  companyName    String
  companyLogoUrl String? // later we will store the logo in S3 and put the URL here

  address1 String
  address2 String?
  city     String
  state    String
  zip      String

  primaryPhone   String
  secondaryPhone String?

  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String

  secondaryContactName  String?
  secondaryContactEmail String?
  secondaryContactPhone String?

  // Link back to the original intake submission (optional but helpful)
  intakeSubmissionId String?           @unique
  intakeSubmission   IntakeSubmission? @relation("VendorIntake", fields: [intakeSubmissionId], references: [id])

  // A vendor can have many orders
  orders VendorOrder[]
}

model VendorOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  // Order info the vendor enters
  signerName     String
  signerAddress1 String
  signerAddress2 String?
  signerCity     String
  signerState    String
  signerZip      String
  signerPhone    String

  // Service type dropdown (we’ll fill the list next)
  serviceType String

  // If they want remote online notarization
  isRON Boolean @default(false)

  // Notes / “Other service” details
  notes String?

  // Tracking
  status String @default("NEW") // NEW, ASSIGNED, COMPLETED, CANCELED
}
