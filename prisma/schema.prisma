generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IntakeSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  role      String
  fullName  String
  email     String
  phone     String?
  message   String?
  details   Json?
  status    String   @default("NEW")
  vendor    Vendor?  @relation("VendorIntake")
}

model Vendor {
  id                    String            @id @default(cuid())
  createdAt             DateTime          @default(now())
  vendorcode            String            @unique
  companyName           String
  companyLogoUrl        String?
  address1              String
  address2              String?
  city                  String
  state                 String
  zip                   String
  primaryPhone          String
  secondaryPhone        String?
  primaryContactName    String
  primaryContactEmail   String
  primaryContactPhone   String
  secondaryContactName  String?
  secondaryContactEmail String?
  secondaryContactPhone String?
  intakeSubmissionId    String?           @unique
  intakeSubmission      IntakeSubmission? @relation("VendorIntake", fields: [intakeSubmissionId], references: [id])
  orders                VendorOrder[]
}

model VendorOrder {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  vendorId       String
  signerName     String
  signerAddress1 String
  signerAddress2 String?
  signerCity     String
  signerState    String
  signerZip      String
  signerPhone    String
  serviceType    String
  isRON          Boolean  @default(false)
  notes          String?
  status         String   @default("NEW")
  vendor         Vendor   @relation(fields: [vendorId], references: [id])
}

model AccessRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  requestType String
  message     String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
